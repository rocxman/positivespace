# Environment
APP_ENV=development
DEBUG=true
APP_NAME=PositiveSpace API
APP_VERSION=0.1.0

# API
API_V1_PREFIX=/api/v1
SECRET_KEY=your-secret-key-change-in-production

# Database - SQLite for local dev (no Docker needed!)
# For production with Docker/PostgreSQL: postgresql+asyncpg://postgres:postgres@localhost:5432/positivespace
DATABASE_URL=sqlite+aiosqlite:///./positivespace.db
DATABASE_SYNC_URL=sqlite:///./positivespace.db

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Security
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Cloudflare R2 (Optional for development)
# R2_ACCOUNT_ID=xxx
# R2_ACCESS_KEY_ID=xxx
# R2_SECRET_ACCESS_KEY=xxx
# R2_BUCKET_NAME=positivespace
# R2_PUBLIC_URL=https://xxx.r2.dev

# AI Services (Optional for development)
# HUGGINGFACE_TOKEN=hf_xxx
# MODAL_TOKEN=xxx
# REPLICATE_API_TOKEN=xxx

# Email (Optional for development)
# RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@localhost

# Stripe (Optional for development)
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# Midtrans (Optional for development)
# MIDTRANS_SERVER_KEY=xxx
# MIDTRANS_IS_PRODUCTION=false

# Sentry (Optional for development)
# SENTRY_DSN=https://xxx@sentry.io/xxx

# Supabase (Optional for development)
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_KEY=xxx
